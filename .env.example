# LLM API Proxy Environment Variables
# Copy this file to .env (for local use) or ~/.llm-proxy.env (for global/service use)
# IMPORTANT: Never commit .env or .llm-proxy.env to version control!

# Primary API Key
PRIMARY_API_KEY=sk-your-primary-api-key-here

# Backup API Key
BACKUP_API_KEY=sk-your-backup-api-key-here

# Custom API Key
CUSTOM_API_KEY=sk-your-custom-api-key-here

# OpenAI API Key (for auth_type: "openai" endpoints)
OPENAI_API_KEY=sk-your-openai-key-here
