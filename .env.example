# LLM API Proxy Environment Variables
# Copy this file to .llm-proxy.env and fill in your actual API keys
# IMPORTANT: Never commit .llm-proxy.env to version control!

# Primary API Key
PRIMARY_API_KEY=sk-your-primary-api-key-here

# Backup API Key
BACKUP_API_KEY=sk-your-backup-api-key-here

# Custom API Key
CUSTOM_API_KEY=sk-your-custom-api-key-here
